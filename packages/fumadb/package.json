{
  "name": "fumadb",
  "description": "A library for interacting with different databases for your package.",
  "version": "0.2.2",
  "repository": "github:fuma-nama/fumadb",
  "author": "Fuma Nama",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./adapters/*": {
      "import": "./dist/adapters/*/index.js",
      "types": "./dist/adapters/*/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "types": "./dist/adapters/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/index.js",
      "types": "./dist/cli/index.d.ts"
    },
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "tsup",
    "dev": "tsup --watch",
    "test:cli": "pnpx tsx ./test/cli.ts"
  },
  "devDependencies": {
    "@convex-dev/aggregate": "^0.2.1",
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/adapter-mssql": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "25.6.0",
    "@types/pg": "^8.20.0",
    "@types/semver": "^7.7.1",
    "better-sqlite3": "^12.9.0",
    "convex": "^1.36.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "mongodb": "^7.2.0",
    "mysql2": "^3.22.3",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tarn": "^3.0.2",
    "tedious": "^19.2.1",
    "tinyexec": "^1.1.2",
    "tsup": "^8.5.1",
    "typeorm": "^0.3.28",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "convex": "^1.25.0",
    "drizzle-orm": "^0.44.0 || ^0.45.0",
    "mongodb": "6.x.x || 7.x.x",
    "prisma": "6.x.x || 7.x.x",
    "typeorm": "0.x.x"
  },
  "peerDependenciesMeta": {
    "convex": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    },
    "prisma": {
      "optional": true
    },
    "typeorm": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "commander": "^14.0.3",
    "kysely": "^0.28.16",
    "kysely-typeorm": "^0.3.0",
    "semver": "^7.7.4",
    "zod": "^4.4.1"
  }
}
